#!/usr/bin/env bash
set -euo pipefail

# Wires Claude Code / Codex / Pi to report agent status to Sidekick: builds the
# helper binaries into ~/.local/bin, installs the sidekick-panes skill, and adds
# the hook entries that name those binaries.
#
# Run it once, by hand, to opt in. After that it is maintenance, and maintenance
# is automatic: install.sh re-runs it (--refresh-only) on every from-source
# install, and an installed .app self-heals the same files on launch. Nobody
# should have to remember this script exists.
#
# Options:
#   --refresh-only        Do nothing unless the integration is already installed.
#                         This is how install.sh calls it: opted-in users get a
#                         silent refresh, everyone else is left alone with a hint.
#   --binaries-from DIR   Take sidekick-agent-status / sidekick-mcp from DIR
#                         instead of building them. install.sh passes the app
#                         bundle it just installed, which skips a redundant
#                         release build AND guarantees the ~/.local/bin helpers
#                         are byte-identical to the ones inside that app.

usage() {
    cat <<'EOF'
Usage: install-agent-status-hooks [--refresh-only] [--binaries-from DIR]

  --refresh-only        Do nothing unless the integration is already installed.
  --binaries-from DIR   Take the helper binaries from DIR instead of building.
EOF
}

refresh_only=0
binaries_from=""

while [ $# -gt 0 ]; do
    case "$1" in
        --refresh-only) refresh_only=1 ;;
        --binaries-from)
            [ $# -ge 2 ] || { echo "--binaries-from needs a directory" >&2; exit 2; }
            binaries_from="$2"
            shift
            ;;
        --binaries-from=*) binaries_from="${1#*=}" ;;
        -h|--help) usage; exit 0 ;;
        *) echo "Unknown option: $1" >&2; usage >&2; exit 2 ;;
    esac
    shift
done

repo="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
bin_dir="${HOME}/.local/bin"
status_bin="${bin_dir}/sidekick-agent-status"
mcp_bin="${bin_dir}/sidekick-mcp"
skill_source="${repo}/.claude/skills/sidekick-panes"
claude_settings="${HOME}/.claude/settings.json"
codex_config="${HOME}/.codex/config.toml"

# Has this machine ever opted in? Two kinds of evidence, either one is enough:
# a hook entry naming our status helper, or the helpers themselves sitting in
# ~/.local/bin. (Hooks written by the app's own Preferences -> Agents installer
# name the copy inside the bundle, and count too — the user opted into hooks
# either way, and the entry dedup below keys on the binary name, not its path,
# so refreshing an app-installed integration adds no duplicate entries.)
integration_installed() {
    if [ -e "$status_bin" ] || [ -e "$mcp_bin" ]; then
        return 0
    fi
    for config in "$claude_settings" "$codex_config"; do
        if [ -f "$config" ] && grep -q 'sidekick-agent-status' "$config"; then
            return 0
        fi
    done
    return 1
}

if [ "$refresh_only" -eq 1 ] && ! integration_installed; then
    cat <<EOF
Agent status integration is not installed, so there is nothing to refresh.

To hook Claude Code/Codex/Pi into Sidekick's agents panel (one time — install.sh
and the app keep it current from then on):

  ${repo}/scripts/install-agent-status-hooks
EOF
    exit 0
fi

mkdir -p "$bin_dir"

if [ -n "$binaries_from" ]; then
    # Binaries handed to us (install.sh passing the app bundle it just
    # installed). Nothing to build.
    for helper in sidekick-agent-status sidekick-mcp; do
        if [ ! -f "${binaries_from}/${helper}" ]; then
            echo "❌ ${binaries_from}/${helper} not found — build the app first (./build-app.sh)." >&2
            exit 1
        fi
    done
    install -m 0755 "${binaries_from}/sidekick-agent-status" "$status_bin"
    install -m 0755 "${binaries_from}/sidekick-mcp" "$mcp_bin"
else
    swift build --package-path "$repo" -c release --product sidekick-agent-status
    swift build --package-path "$repo" -c release --product sidekick-mcp
    install -m 0755 "$repo/.build/release/sidekick-agent-status" "$status_bin"
    install -m 0755 "$repo/.build/release/sidekick-mcp" "$mcp_bin"
fi

# Install the same pane-orchestration skill for Claude Code, Codex, and Pi.
# All three load Agent Skills standard SKILL.md files; Pi reads ~/.pi/agent/skills.
for skill_root in "${HOME}/.claude/skills" "${HOME}/.codex/skills" "${HOME}/.pi/agent/skills"; do
    mkdir -p "${skill_root}/sidekick-panes/agents"
    install -m 0644 "${skill_source}/SKILL.md" "${skill_root}/sidekick-panes/SKILL.md"
    install -m 0644 "${skill_source}/agents/openai.yaml" "${skill_root}/sidekick-panes/agents/openai.yaml"
done

python3 - "$claude_settings" "$status_bin" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
status_bin = sys.argv[2]
path.parent.mkdir(parents=True, exist_ok=True)

if path.exists() and path.read_text().strip():
    data = json.loads(path.read_text())
else:
    data = {}

hooks = data.setdefault("hooks", {})

def signature(command):
    """Binary name + arguments: '/a/b/sidekick-agent-status busy' -> 'sidekick-agent-status busy'.

    Hooks are deduped on this rather than the full command, so an entry pointing
    at the copy inside Sidekick.app (what the app's Preferences -> Agents
    installer writes) counts as the same hook as one pointing at ~/.local/bin,
    and re-running this script over an app-installed integration adds no
    duplicate entries. Mirrors AgentIntegrationInstaller.addClaudeHook.
    """
    parts = (command or "").replace("'", "").split()
    if not parts:
        return ""
    return " ".join([parts[0].rsplit("/", 1)[-1]] + parts[1:])

def add_hook(event, command, matcher=None):
    groups = hooks.setdefault(event, [])
    for group in groups:
        for hook in group.get("hooks", []):
            if hook.get("type") == "command" and signature(hook.get("command")) == signature(command):
                return
    group = {"hooks": [{"type": "command", "command": command}]}
    if matcher:
        group["matcher"] = matcher
    groups.append(group)

def remove_hook(event, signature):
    groups = hooks.get(event)
    if not groups:
        return
    kept = []
    for group in groups:
        hooks_list = [
            h for h in group.get("hooks", [])
            if signature not in (h.get("command") or "")
        ]
        if hooks_list:
            group["hooks"] = hooks_list
            kept.append(group)
    if kept:
        hooks[event] = kept
    else:
        hooks.pop(event, None)

# The PreToolUse diff-review hook (sidekick-hook) is no longer shipped — it
# duplicated Claude Code's own approval prompt. Strip it from older installs.
remove_hook("PreToolUse", "sidekick-hook")

# This event list mirrors AgentIntegrationInstaller (statusHooks +
# sharedRefinementHooks + claudeOnlyStatusHooks); the two installers write the
# same contract or the app's launch reconcile "repairs" a script install on
# every start. An earlier version of this script removed PermissionRequest as
# nonexistent, but current Claude Code fires it whenever a permission prompt
# is shown — it is the primary "needs input" signal.
add_hook("UserPromptSubmit", f"{status_bin} busy")
add_hook("Notification", f"{status_bin} ready")
add_hook("PermissionRequest", f"{status_bin} ready")
# Marks the pane busy the instant a tool call starts.
add_hook("PreToolUse", f"{status_bin} busy")
# No hook fires when the user ANSWERS a permission prompt; tool completion is
# the earliest authoritative busy signal after an approval, so an answered
# prompt doesn't sit on "Needs input" until the next PreToolUse or Stop.
add_hook("PostToolUse", f"{status_bin} busy")
add_hook("PostToolUseFailure", f"{status_bin} busy")
add_hook("Stop", f"{status_bin} done")
# Clears the tab from the agents panel when the session ends.
add_hook("SessionEnd", f"{status_bin} idle")

path.write_text(json.dumps(data, indent=2) + "\n")
PY

python3 - "$codex_config" "$status_bin" <<'PY'
import json
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
status_bin = sys.argv[2]
path.parent.mkdir(parents=True, exist_ok=True)
text = path.read_text() if path.exists() else ""

def ensure_hooks_enabled(text):
    features = re.search(r"(?m)^\[features\]\s*$", text)
    if not features:
        block = "[features]\nhooks = true\n\n"
        first_table = re.search(r"(?m)^\[\[?[^\]]+\]?\]\s*$", text)
        if not first_table:
            return text.rstrip() + "\n\n" + block
        return text[:first_table.start()].rstrip() + "\n\n" + block + text[first_table.start():].lstrip()

    next_table = re.search(r"(?m)^\[[^\]]+\]\s*$", text[features.end():])
    section_end = len(text) if not next_table else features.end() + next_table.start()
    section = text[features.end():section_end]

    section = re.sub(r"(?m)^\s*codex_hooks\s*=.*\n?", "", section)
    if re.search(r"(?m)^\s*hooks\s*=", section):
        section = re.sub(r"(?m)^(\s*hooks\s*=\s*).*$", r"\1true", section)
    else:
        section = "\nhooks = true" + section

    return text[:features.end()] + section + text[section_end:]

text = ensure_hooks_enabled(text)

# Mirrors AgentIntegrationInstaller.installCodex (statusHooks +
# sharedRefinementHooks) so the app's launch reconcile doesn't "repair" a
# script install on every start.
commands = {
    "UserPromptSubmit": f"{status_bin} busy",
    "PermissionRequest": f"{status_bin} ready",
    "PreToolUse": f"{status_bin} busy",
    "Stop": f"{status_bin} done",
}

def signature(command):
    """Binary name + arguments — see the Claude block above for why we dedup on this."""
    parts = (command or "").replace("'", "").split()
    if not parts:
        return ""
    return " ".join([parts[0].rsplit("/", 1)[-1]] + parts[1:])

def event_has_command(event, command):
    """True when a [[hooks.<event>]] table already runs this hook (any path)."""
    wanted = signature(command)
    table = None
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith("[["):
            table = stripped
        elif stripped.startswith("command") and table and table.startswith(f"[[hooks.{event}"):
            value = stripped.split("=", 1)[1].strip().strip('"')
            if signature(value) == wanted:
                return True
    return False

for event, command in commands.items():
    if event_has_command(event, command):
        continue
    text = text.rstrip() + "\n\n" + "\n".join([
        f"[[hooks.{event}]]",
        f"[[hooks.{event}.hooks]]",
        'type = "command"',
        f"command = {json.dumps(command)}",
    ]) + "\n"

path.write_text(text)
PY

# Pi coding agent: install the status extension when pi is set up.
pi_note=""
if [ -d "${HOME}/.pi/agent" ]; then
    mkdir -p "${HOME}/.pi/agent/extensions"
    install -m 0644 "$repo/scripts/pi-sidekick-status.ts" "${HOME}/.pi/agent/extensions/sidekick-status.ts"
    pi_note="  ${HOME}/.pi/agent/extensions/sidekick-status.ts"
fi

# Register the MCP server with Claude Code via the canonical `claude mcp add`
# (user scope), idempotently. Other MCP clients (Claude Desktop, Cursor) can
# use the .mcp.json snippet in the README.
if command -v claude >/dev/null 2>&1; then
    if claude mcp list 2>/dev/null | grep -q "sidekick"; then
        mcp_note="  Claude Code MCP server 'sidekick' (already registered)"
    elif claude mcp add --scope user sidekick "$mcp_bin" >/dev/null 2>&1; then
        mcp_note="  Registered Claude Code MCP server 'sidekick' -> $mcp_bin"
    else
        mcp_note="  Could not auto-register; run: claude mcp add --scope user sidekick \"$mcp_bin\""
    fi
else
    mcp_note="  Register with your MCP client (e.g. claude mcp add --scope user sidekick \"$mcp_bin\")"
fi

cat <<EOF
Installed:
  $status_bin
  $mcp_bin (MCP server)
  $HOME/.claude/skills/sidekick-panes/SKILL.md
  $HOME/.codex/skills/sidekick-panes/SKILL.md
  $HOME/.pi/agent/skills/sidekick-panes/SKILL.md
${pi_note}

Updated:
  $HOME/.claude/settings.json
  $HOME/.codex/config.toml

MCP server:
${mcp_note}

Restart Claude Code/Codex/pi sessions for hook and MCP changes to take effect.
EOF
