#!/usr/bin/env bash
set -euo pipefail

repo="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
bin_dir="${HOME}/.local/bin"
status_bin="${bin_dir}/sidekick-agent-status"
hook_bin="${bin_dir}/sidekick-hook"

mkdir -p "$bin_dir"
swift build --package-path "$repo" -c release --product sidekick-agent-status
swift build --package-path "$repo" -c release --product sidekick-hook
install -m 0755 "$repo/.build/release/sidekick-agent-status" "$status_bin"
install -m 0755 "$repo/.build/release/sidekick-hook" "$hook_bin"

python3 - "$HOME/.claude/settings.json" "$status_bin" "$hook_bin" <<'PY'
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
status_bin = sys.argv[2]
hook_bin = sys.argv[3]
path.parent.mkdir(parents=True, exist_ok=True)

if path.exists() and path.read_text().strip():
    data = json.loads(path.read_text())
else:
    data = {}

hooks = data.setdefault("hooks", {})

def add_hook(event, command, matcher=None):
    groups = hooks.setdefault(event, [])
    for group in groups:
        for hook in group.get("hooks", []):
            if hook.get("type") == "command" and hook.get("command") == command:
                return
    group = {"hooks": [{"type": "command", "command": command}]}
    if matcher:
        group["matcher"] = matcher
    groups.append(group)

add_hook("UserPromptSubmit", f"{status_bin} busy")
add_hook("PermissionRequest", f"{status_bin} ready")
add_hook("Stop", f"{status_bin} done")
# Show file edits in Sidekick for accept/reject before they're applied.
add_hook("PreToolUse", hook_bin, matcher="Write|Edit|MultiEdit")

path.write_text(json.dumps(data, indent=2) + "\n")
PY

python3 - "$HOME/.codex/config.toml" "$status_bin" <<'PY'
import json
import pathlib
import re
import sys

path = pathlib.Path(sys.argv[1])
status_bin = sys.argv[2]
path.parent.mkdir(parents=True, exist_ok=True)
text = path.read_text() if path.exists() else ""

def ensure_hooks_enabled(text):
    features = re.search(r"(?m)^\[features\]\s*$", text)
    if not features:
        block = "[features]\nhooks = true\n\n"
        first_table = re.search(r"(?m)^\[\[?[^\]]+\]?\]\s*$", text)
        if not first_table:
            return text.rstrip() + "\n\n" + block
        return text[:first_table.start()].rstrip() + "\n\n" + block + text[first_table.start():].lstrip()

    next_table = re.search(r"(?m)^\[[^\]]+\]\s*$", text[features.end():])
    section_end = len(text) if not next_table else features.end() + next_table.start()
    section = text[features.end():section_end]

    section = re.sub(r"(?m)^\s*codex_hooks\s*=.*\n?", "", section)
    if re.search(r"(?m)^\s*hooks\s*=", section):
        section = re.sub(r"(?m)^(\s*hooks\s*=\s*).*$", r"\1true", section)
    else:
        section = "\nhooks = true" + section

    return text[:features.end()] + section + text[section_end:]

text = ensure_hooks_enabled(text)

commands = {
    "UserPromptSubmit": f"{status_bin} busy",
    "PermissionRequest": f"{status_bin} ready",
    "Stop": f"{status_bin} done",
}

for event, command in commands.items():
    if command in text and f"[[hooks.{event}]]" in text:
        continue
    text = text.rstrip() + "\n\n" + "\n".join([
        f"[[hooks.{event}]]",
        f"[[hooks.{event}.hooks]]",
        'type = "command"',
        f"command = {json.dumps(command)}",
    ]) + "\n"

path.write_text(text)
PY

cat <<EOF
Installed:
  $status_bin
  $hook_bin (PreToolUse edit review)

Updated:
  $HOME/.claude/settings.json
  $HOME/.codex/config.toml

Restart Claude Code/Codex sessions for hook changes to take effect.
EOF
